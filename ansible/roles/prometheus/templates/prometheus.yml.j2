global:
  scrape_interval: 15s
  evaluation_interval: 15s

# 新增：加载告警规则
rule_files:
  - "/etc/prometheus/alert_rules.yml"  # ← 关键！之前漏了这行

scrape_configs:
  - job_name: 'ubuntu-local'
    static_configs:
      - targets: ['localhost:9100']
        labels:
          instance: 'Ubuntu监控中心'
          os: 'Ubuntu'

  - job_name: 'rocky-node'
    static_configs:
      - targets: ['{{ hostvars["rocky"].ansible_host }}:9100']
        labels:
          instance: 'Rocky应用服务器'
          os: 'Rocky'

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['localhost:9093']
